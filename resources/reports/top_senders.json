{
  "id": "top_senders",
  "name": "Top Senders Distribution",
  "description": "Analysis of spending by vendors/senders.",
  "filter_query": {
    "operator": "AND",
    "conditions": [
      {
        "field": "status",
        "op": "equals",
        "value": "PROCESSED"
      }
    ]
  },
  "group_by": "sender",
  "aggregations": [
    {
      "field": "amount",
      "op": "sum"
    }
  ],
  "visualizations": [],
  "components": [
    {
      "type": "pie_chart",
      "content": null,
      "settings": {}
    }
  ]
}